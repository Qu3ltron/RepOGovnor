#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
manifest="${root}/plugins/agent-governance/rust/task-registry-flow-cli/Cargo.toml"

if [[ ! -f "$manifest" ]]; then
  manifest="{{PLUGIN_ROOT}}/rust/task-registry-flow-cli/Cargo.toml"
fi

cd "$root"
export CARGO_TARGET_DIR="${AGENT_GOVERNANCE_CARGO_TARGET_DIR:-/tmp/agent-governance-cargo-target}"
exec cargo run --locked --quiet --manifest-path "$manifest" -- "$@"
