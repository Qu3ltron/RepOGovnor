{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "GOVERNANCE_HOOK_FORMAT=codex bash \"$(git rev-parse --show-toplevel)/{{MUTATION_HOOK_SCRIPT}}\" --format codex",
            "timeout": 60,
            "statusMessage": "Checking registry-bound mutation"
          }
        ]
      }
    ]
  }
}
