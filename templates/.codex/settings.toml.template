# Machine-readable governance for Codex sessions.
# Antigravity reads GEMINI.md, AGENTS.md, .gemini/settings.json, and .agents/skills/.
# Skill content is canonical under .cursor/skills/.

[workspace_boundary]
repo_name = "{{REPO_NAME}}"
repo_root = "{{REPO_ROOT}}"
allowed_mutation_roots = ["{{REPO_ROOT}}"]
allowed_scratch_root = "{{SCRATCH_ROOT}}"
branch_rule = "Use the branch the user names for this repository."
mutation_rule = "Before editing, confirm git rev-parse --show-toplevel matches repo_root. Do not write outside allowed_mutation_roots except project-isolated scratch under allowed_scratch_root."
push_rule = "Push only when the user explicitly asks."

[project_governance]
constitution_path = "{{CONSTITUTION_PATH}}"
vision_path = "{{VISION_PATH}}"
agents_path = "AGENTS.md"
antigravity_context_path = "GEMINI.md"
design_docs_path = "{{DESIGN_DOCS_PATH}}"
design_rule = "Follow project authority order and architecture docs. This plugin supplies workflow only."

[authority]
order = {{AUTHORITY_ORDER_TOML}}

[agent_paths]
codex_settings_path = ".codex/settings.toml"
codex_hook_path = ".codex/hooks/user-plan-approval.toml"
codex_skills_path = ".cursor/skills"
canonical_skills_path = ".cursor/skills"
antigravity_settings_path = ".gemini/settings.json"
antigravity_skills_path = ".agents/skills"
antigravity_hooks_path = ".agents/hooks.json"
antigravity_mutation_hook_script = "{{MUTATION_HOOK_SCRIPT}}"

[gap_closure_contract]
skill_name = "gap-closure-contract"
skill_path = ".cursor/skills/gap-closure-contract"
hook_path = ".codex/hooks/user-plan-approval.toml"
mandatory_after_plan_approval = true
contract_required_before_mutation = true
contract_path_pattern = "docs/plans/<short-slug>.md"
scratch_root = "{{SCRATCH_ROOT}}"
approval_triggers = [
  "Implement the plan",
  "approved",
  "proceed",
  "continue",
  "close these gaps",
  "use this to close",
  "reviewer output followed by a fix instruction"
]
required_sections = [
  "Approved Scope",
  "Required Change Checklist",
  "Per-Gap Success Criteria",
  "Validation Plan",
  "Walkthrough Evidence",
  "Task Manifest"
]
behavioral_contract_required = true
design_rule = "After gap analysis plus user approval, load gap-closure-contract and create or refresh docs/plans/<short-slug>.md before code edits. Include [[behaviors]] with runnable confirmations, per-gap Behavioral criteria, and PLAN_ACTIVATE through the registry CLI before implementation."

[task_registry]
registry_path = "{{REGISTRY_PATH}}"
plans_path = "{{PLANS_PATH}}"
skill_name = "task-registry-flow"
skill_path = ".cursor/skills/task-registry-flow"
manifest_section = "Task Manifest"
activation_opcode = "PLAN_ACTIVATE"
status_opcode = "TASK_STATUS"
defer_opcode = "TASK_DEFER"
report_opcode = "TASK_REPORT"
cli_command = "{{TASK_REGISTRY_CLI}}"
typed_validation_command = "{{TASK_REGISTRY_CLI}} validate"
verify_behaviors_command = "{{TASK_REGISTRY_CLI}} verify-behaviors"
verify_mutation_hook_command = "{{VERIFY_HOOK_COMMAND}}"
registry_authoritative_after_activation = true
activation_required_before_implementation = true
final_report_required = true
archive_dir = "{{ARCHIVE_DIR}}"
deferred_without_governed_reason_forbidden = true
deferred_governance_basis_required = true
deferred_reactivation_condition_required = true
deferred_status_requires_defer_opcode = true
status_vocabulary = ["planned", "active", "blocked", "deferred", "completed", "cancelled"]
hash_algorithm = "sha256 of normalized plan text: CRLF/CR converted to LF, trailing whitespace stripped from each line, exactly one final newline"
design_rule = "Consult .cursor/skills/task-registry-flow/SKILL.md before registry work. Use the configured registry CLI for activate, status, defer, report, validate, and verify-behaviors."

[validation]
focused = {{VALIDATION_FOCUSED_TOML}}
full = {{VALIDATION_FULL_TOML}}
design_rule = "Validation Plan commands in each contract override these defaults when they are more specific."

{{COMMIT_GOVERNANCE_TOML}}
