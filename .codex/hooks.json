{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "GOVERNANCE_HOOK_FORMAT=codex bash \"$(git rev-parse --show-toplevel)/tools/agent-governance/pre-tool-use-gap-closure.sh\" --format codex",
            "timeout": 60,
            "statusMessage": "Checking registry-bound mutation"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "GOVERNANCE_HOOK_FORMAT=codex bash \"$(git rev-parse --show-toplevel)/tools/agent-governance/pre-tool-use-gap-closure.sh\" --format codex",
            "timeout": 60,
            "statusMessage": "Recording mutation model attribution"
          }
        ]
      }
    ]
  }
}
